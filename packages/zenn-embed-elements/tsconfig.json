{
  "compilerOptions": {
    "target": "es6", // important for web components
    "module": "commonjs",
    "declaration": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "moduleResolution": "node",
    // TODO: TypeScript 6の根本対応（moduleResolution移行）後に削除する一時回避策
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["node_modules", "lib"],
  "include": ["**/*.ts", "**/*.tsx"]
}
